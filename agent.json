{
  "id": "a2a-sin-simone-mcp",
  "displayName": "SIN-Simone-MCP",
  "team": "team-coding",
  "description": "Production-grade MCP 2.0 code worker with streamable HTTP, stdio transport, symbol operations, OAuth 2.1 readiness, and hybrid memory.",
  "version": "2026.06.30",
  "deployment": {
    "workforceIndex": "https://opensin.ai",
    "landingPage": "https://opensin.ai/agents/simone-mcp",
    "publicA2A": "http://localhost:8234/a2a/v1",
    "cimdAnchor": "http://localhost:8234",
    "vmServer": "Target: Hugging Face Space free CPU VM"
  },
  "a2a": {
    "wellKnownCard": "/.well-known/agent-card.json",
    "rpcPath": "/a2a/v1",
    "transport": "jsonrpc-over-http"
  },
  "mcp": {
    "transport": "stdio+streamable-http",
    "configPath": "./mcp-config.json"
  },
  "marketplace": {
    "pricingModel": "enterprise_tier",
    "monthlyPrice": 4999,
    "purchaseModes": [
      "subscription"
    ],
    "category": "Elite Coding"
  },
  "primaryModel": "openai/gpt-5.4",
  "fallbackModel": "nvidia/minimaxai/minimax-m2.7",
  "skills": [
    {
      "id": "agent.help",
      "name": "Get Help",
      "description": "Get help information about this agent's capabilities",
      "inputModes": [
        "application/json"
      ],
      "outputModes": [
        "application/json",
        "text/plain"
      ]
    },
    {
      "id": "sin_simone_mcp_health",
      "name": "Health Check",
      "description": "Check Simone MCP readiness, model, and capabilities",
      "inputModes": [
        "application/json"
      ],
      "outputModes": [
        "application/json",
        "text/plain"
      ]
    },
    {
      "id": "sin_simone_mcp_symbol_search",
      "name": "Symbol Search",
      "description": "Search for symbols across the codebase using LSP-powered semantic analysis",
      "inputModes": [
        "application/json"
      ],
      "outputModes": [
        "application/json",
        "text/plain"
      ]
    },
    {
      "id": "sin_simone_mcp_structural_edit",
      "name": "Structural Edit",
      "description": "Perform structural code edits using LSP-grade symbol resolution and refactoring",
      "inputModes": [
        "application/json"
      ],
      "outputModes": [
        "application/json",
        "text/plain"
      ]
    },
    {
      "id": "sin_simone_mcp_memory_query",
      "name": "Memory Query",
      "description": "Query the cloud semantic memory for code context and prior analysis results",
      "inputModes": [
        "application/json"
      ],
      "outputModes": [
        "application/json",
        "text/plain"
      ]
    },
    {
      "id": "sin_simone_mcp_find_references",
      "name": "Find References",
      "description": "Find textual references to a symbol across a workspace",
      "inputModes": [
        "application/json"
      ],
      "outputModes": [
        "application/json",
        "text/plain"
      ]
    },
    {
      "id": "sin_simone_mcp_project_overview",
      "name": "Project Overview",
      "description": "Summarize the workspace footprint and primary file types",
      "inputModes": [
        "application/json"
      ],
      "outputModes": [
        "application/json",
        "text/plain"
      ]
    }
  ],
  "securitySchemes": {
    "oauth2": {
      "type": "oauth2",
      "flows": {
        "authorizationCode": {
          "authorizationUrl": "https://opensin.ai/authorize",
          "tokenUrl": "https://opensin.ai/token",
          "scopes": {
            "simone.read": "Read-only symbol and project queries",
            "simone.write": "Structural code edits"
          }
        }
      }
    }
  },
  "security": [
    {
      "oauth2": [
        "simone.read"
      ]
    }
  ],
  "defaultInputModes": [
    "application/json",
    "text/plain"
  ],
  "defaultOutputModes": [
    "application/json",
    "text/plain"
  ],
  "capabilities": {
    "streaming": true,
    "pushNotifications": false
  }
